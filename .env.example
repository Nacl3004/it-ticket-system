# IT运维工单系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际的配置值

# ==================== 数据库配置 ====================
# 数据库地址（必填）
DB_HOST=localhost

# 数据库端口（必填）
DB_PORT=3306

# 数据库用户名（必填）
DB_USER=your_database_user

# 数据库密码（必填）
DB_PASSWORD=your_database_password

# 数据库名称（必填）
DB_NAME=it_ticket_system

# 数据库会话时区（可选）
# 留空时跟随数据库服务器自身时区；需要固定时区时可填 +08:00、+00:00 等
DB_TIME_ZONE=

# ==================== 应用配置 ====================
# JWT密钥（必填，至少32位随机字符串）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-characters

# 应用环境（可选）
# 可选值: development, production
APP_ENV=production

# 应用进程时区（可选，Docker 本地开发时常用；宝塔部署通常跟随服务器时区即可）
TZ=

# 调试模式（可选）
# 可选值: true, false
APP_DEBUG=false

# ==================== CORS配置 ====================
# 允许的跨域源（可选）
# 多个源用逗号分隔，例如: https://example.com,https://app.example.com
# 使用 * 允许所有源（不推荐用于生产环境）
CORS_ORIGINS=*

# ==================== 其他配置 ====================
# 应用端口（可选）
APP_PORT=8000

# 应用主机（可选）
APP_HOST=0.0.0.0

# ==================== 注意事项 ====================
# 1. 生产环境必须修改 SECRET_KEY 为随机字符串
# 2. 不要将此文件提交到版本控制系统（已在.gitignore中）
# 3. 确保数据库配置正确且数据库已创建
# 4. 建议使用强密码策略
# 5. 生产环境建议关闭调试模式（APP_DEBUG=false）
